<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # API proxy folders (PHP forwarder) — do not route to SPA
  RewriteRule ^(mobile_app|pos_phone_app)/ - [L]

  # Don't rewrite actual files or directories
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Route all other requests to index.html for client-side routing
  RewriteRule ^ index.html [QSA,L]
</IfModule>

# Gzip compression for better performance
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Browser caching
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Default: 1 hour
  ExpiresDefault "access plus 1 hour"
  
  # Cache HTML files for 5 minutes
  ExpiresByType text/html "access plus 5 minutes"
  
  # Cache CSS/JS for 1 year (versioned files)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
</IfModule>
